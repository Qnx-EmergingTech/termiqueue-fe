{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "types": [
      "react",
      "react-native"
    ],
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
